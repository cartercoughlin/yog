<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>NSHealthShareUsageDescription</key>
    <string>We need access to your health data to calculate your recovery score and provide personalized workout recommendations.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>We need permission to save workout data to your Health app.</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>We need your location to display current local weather conditions on the home screen.</string>
    <key>NSFamilyControlsUsageDescription</key>
    <string>Track your screen time to optimize mental recovery and overall wellness. Lower screen time contributes to better recovery scores. Navigation and music apps are automatically excluded from tracking.</string>
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <true/>
    </dict>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>healthkit</string>
    </array>
    <key>CFBundleDisplayName</key>
    <string>Recovery</string>
    <key>CFBundleIdentifier</key>
    <string>com.yourcompany.RecoveryApp</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>LSApplicationQueriesSchemes</key>
    <array>
        <string>com.garmin.connect.mobile</string>
        <string>strava</string>
    </array>
</dict>
</plist>
