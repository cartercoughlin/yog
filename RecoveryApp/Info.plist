    <string>Recovery</string>
    <key>CFBundleIdentifier</key>
    <string>com.yourcompany.RecoveryApp</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
